                                <Border Background="{DynamicResource WindowBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1" CornerRadius="4" Padding="4" Margin="0,0,0,6">
                                    <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                                        <ItemsControl x:Name="LstShortcuts">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <DockPanel Margin="0,0,0,4">
                                                        <Button Content="✏" DockPanel.Dock="Right"
                                                                Tag="{Binding}"
                                                                Click="BtnEditShortcut_Click"
                                                                Background="Transparent" Foreground="{DynamicResource MutedForegroundBrush}"
                                                                BorderBrush="Transparent" FontSize="14"
                                                                Padding="4,0" Cursor="Hand" VerticalAlignment="Center"
                                                                ToolTip="Edit shortcut"/>
                                                        <TextBlock Text="{Binding Name}" Foreground="{DynamicResource ForegroundBrush}"
                                                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                    </DockPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Border>
                                <TextBlock x:Name="TxtNoShortcuts" Text="No shortcuts configured."
                                           Foreground="{DynamicResource MutedForegroundBrush}" Margin="0,0,0,4"
                                           Visibility="Collapsed"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel x:Name="PanelAddWidgets" Margin="0,12,0,0">
                    <TextBlock Text="Add Widgets" FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>
                    <ItemsControl x:Name="LstWidgetTypes">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,0,0,10">
                                    <TextBlock Text="{Binding Key}" FontSize="14" FontWeight="SemiBold"
                                               Foreground="{DynamicResource MutedForegroundBrush}" Margin="0,0,0,4"/>
                                    <ItemsControl ItemsSource="{Binding}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Content="{Binding Name, StringFormat=Add {0}}"
                                                        Tag="{Binding Name}"
                                                        Click="BtnAddWidget_Click"
                                                        Padding="10,6" Margin="0,0,6,6"
                                                        Background="{DynamicResource AccentBrush}" Foreground="White" BorderBrush="Transparent" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <StackPanel x:Name="PanelActiveWidgets" Margin="0,12,0,0">
                    <TextBlock Text="Active Widgets" FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>
                    <Border Background="{DynamicResource ControlBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            CornerRadius="4" Padding="12">
                        <Grid>
                            <ListBox x:Name="LstActiveWidgets"
                                         MinHeight="120"
                                         MaxHeight="220"
                                         Background="Transparent"
                                         Foreground="{DynamicResource ForegroundBrush}"
                                         BorderThickness="0"
                                         MouseDoubleClick="LstActiveWidgets_MouseDoubleClick"
                                         PreviewMouseRightButtonUp="LstActiveWidgets_PreviewMouseRightButtonUp">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,0,8,0"/>

                                            <Button Grid.Column="1"
                                                    Content="X"
                                                    Width="24"
                                                    Height="24"
                                                    Tag="{Binding Id}"
                                                    Click="BtnCloseActiveWidget_Click"
                                                    Background="{DynamicResource SecondaryButtonBrush}"
                                                    Foreground="White"
                                                    BorderBrush="Transparent"
                                                    ToolTip="Close widget"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <TextBlock x:Name="TxtNoActiveWidgets"
                                       Text="No active widgets are open."
                                       Visibility="Collapsed"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource MutedForegroundBrush}"/>
                        </Grid>
                    </Border>
                </StackPanel>

                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                <Button Content="Save" Click="BtnSave_Click" Padding="20,8" Margin="0,0,8,0"
                        Background="{DynamicResource AccentBrush}" Foreground="White" BorderBrush="Transparent"/>
                <Button Content="Apply" Click="BtnApply_Click" Padding="20,8" Margin="0,0,8,0"
                        Background="{DynamicResource AccentBrush}" Foreground="White" BorderBrush="Transparent"/>
                <Button Content="Close" Click="BtnClose_Click" Padding="20,8"
                        Background="{DynamicResource SecondaryButtonBrush}" Foreground="White" BorderBrush="Transparent"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
